# Copiez ce fichier en .env à la racine du projet

# ── Site ──
# Production :
DOMAIN=https://lesbonscontacts.com
API_BASE=https://lesbonscontacts.com
# Local : DOMAIN=http://localhost:4242 et API_BASE=http://localhost:4242
PORT=4242
FLASK_DEBUG=true
PROTECT_DOWNLOADS=true

# ── Stripe ──
# Dashboard : https://dashboard.stripe.com/apikeys
# Mode : live (production) ou test (local) — auto-détecté si omis
STRIPE_MODE=live

# Production Vercel (clés LIVE) :
STRIPE_SECRET_KEY=sk_live_VOTRE_CLE_SECRETE
STRIPE_PUBLISHABLE_KEY=pk_live_VOTRE_CLE_PUBLIQUE
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_SECRET_WEBHOOK

# Local uniquement (clés TEST) :
# STRIPE_MODE=test
# STRIPE_SECRET_KEY=sk_test_VOTRE_CLE_SECRETE
# STRIPE_PUBLISHABLE_KEY=pk_test_VOTRE_CLE_PUBLIQUE

# ── Supabase ──
# Dashboard : https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://VOTRE_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ_VOTRE_CLE_ANON
SUPABASE_SERVICE_ROLE_KEY=eyJ_VOTRE_CLE_SERVICE_ROLE

# Sans Supabase configuré, le site fonctionne en mode local (localStorage) — dev uniquement.
